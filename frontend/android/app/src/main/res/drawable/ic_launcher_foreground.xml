<?xml version="1.0" encoding="utf-8"?>
<vector
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Heart shape centered within the 108x108 adaptive icon (offset 14,14 from the 80x80 source) -->
    <group
        android:translateX="14"
        android:translateY="14">

        <!-- Heart path with gradient fill -->
        <path
            android:pathData="M40,70 C40,70 8,48 8,28 C8,16 17,8 28,8 C33.5,8 38,10.5 40,14 C42,10.5 46.5,8 52,8 C63,8 72,16 72,28 C72,48 40,70 40,70Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="linear"
                    android:startX="8"
                    android:startY="8"
                    android:endX="72"
                    android:endY="70">
                    <item android:offset="0.0" android:color="#FF0ea5e9"/>
                    <item android:offset="0.5" android:color="#FF0d9488"/>
                    <item android:offset="1.0" android:color="#FF0ea5e9"/>
                </gradient>
            </aapt:attr>
        </path>

        <!-- ECG/Pulse line -->
        <path
            android:pathData="M12,40 L26,40 L30,40 L34,32 L38,50 L42,28 L46,46 L50,36 L54,40 L68,40"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="3.5"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:fillColor="#00000000"/>
    </group>
</vector>
